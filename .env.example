# Local-only example. Copy to C:\tmp\dge\caesars\.env and fill real values.
# Do not commit real secrets or private keys.

# Option A: Azure Blob API with App Registration / service principal.
# This is the preferred production-like local path once IAM access is granted.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=28aa5709-ef31-48d7-b919-c858650b52af
AZURE_CLIENT_SECRET=

DGE_STORAGE_ACCOUNT=awagersftp
DGE_STORAGE_CONTAINER=c8-nj-prod
DGE_STORAGE_PREFIX=
DGE_BRAND=caesars-nj
DGE_SFTP_BRAND=caesars-nj
DGE_FABRIC_BRAND=caesars-nj
DGE_BLOB_LOCAL_DIR=C:\tmp\dge\caesars\sftp

# Option B: Fabric OneLake API with App Registration / service principal.
# If FABRIC_* credentials are empty, the scripts reuse AZURE_* credentials.
FABRIC_TENANT_ID=
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=
FABRIC_WORKSPACE_ID=912d99dd-0947-4c54-ab3b-166a11cf0f0e
FABRIC_LAKEHOUSE_ID=f4d2b03c-4a71-42ac-887b-6394865db591
FABRIC_FOLDER=Files/auto_reports/regulatory/caesars-nj
FABRIC_ONELAKE_HOST=onelake.dfs.fabric.microsoft.com

# Option C: Azure Storage SFTP local user with SSH key.
DGE_SFTP_HOST=awagersftp.blob.core.windows.net
DGE_SFTP_PORT=22
DGE_SFTP_USERNAME=awagersftp.dge-caesars-reader
DGE_SFTP_PRIVATE_KEY=C:\Users\YuliaFarber\.ssh\dge_caesars_sftp
DGE_SFTP_REMOTE_DIR=/c8-nj-prod

DGE_FABRIC_DIR=C:\tmp\dge\caesars\fabric
DGE_OUTPUT_DIR=C:\tmp\dge\caesars\out

# Optional MCP brand-specific defaults for FD / FanDuel.
# SFTP files/folder use fd; Fabric folder/files use fanduel-nj.
DGE_FD_STORAGE_PREFIX=fd
DGE_FD_SFTP_REMOTE_DIR=/c8-nj-prod/fd
DGE_FD_SFTP_LOCAL_DIR=C:\tmp\dge\fd\sftp
DGE_FD_BLOB_LOCAL_DIR=C:\tmp\dge\fd\sftp
DGE_FD_FABRIC_FOLDER=Files/auto_reports/regulatory/fanduel-nj
DGE_FD_FABRIC_DIR=C:\tmp\dge\fd\fabric
DGE_FD_OUTPUT_DIR=C:\tmp\dge\fd\out
